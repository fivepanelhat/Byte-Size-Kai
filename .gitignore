# Blue Moon Portal - Git Exclusions

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing & Coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Linting
.mypy_cache/
.pylint.d/

# Environment Variables (DO NOT COMMIT)
.env
.env.local
.env.*.local

# Telemetry Data (Storage)
telemetry_data/media/*
telemetry_data/sensor_logs/*
!telemetry_data/media/.gitkeep
!telemetry_data/sensor_logs/.gitkeep

# Temporary Files
*.tmp
*.log
*.pid

# OS-specific
Thumbs.db
.DS_Store
*.swp
.AppleDouble
.LSOverride

# Optional: Exclude large model files if versioning locally
# ollama_models/

# Coastal Alpine Tech - Portal SecOps
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
.secrets.baseline
tls-certs/

# Web/Portal specific
node_modules/
dist/
build/
coverage/


# Non-product bulk / Colab exports
track_and_zap.py
flywheel_*.jsonl
!flywheel_*.jsonl.example

