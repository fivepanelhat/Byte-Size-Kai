# Blue Moon Portal - Environment Configuration Template
# 
# Copy this file to .env and fill in your actual values:
# cp .env.example .env
#

# ============================================================================
# OLLAMA CONFIGURATION (Local LLM Runtime)
# ============================================================================

# Ollama API host and port
# Local development: http://localhost:11434
# Remote Ollama: http://<remote-ip>:11434
OLLAMA_HOST=http://localhost:11434

# Model to use for LLM inference
# Supported: gemma4:e4b (Gemma 4 E4B - recommended for RPi 5)
# Alternative: mistral, neural-chat, llama2 (if available)
OLLAMA_MODEL=gemma4:e4b

# ============================================================================
# MQTT CONFIGURATION (Sensor Telemetry)
# ============================================================================

# MQTT broker hostname or IP address
# Local: localhost or 127.0.0.1
# Network: <broker-ip> or <broker-hostname>
MQTT_BROKER=localhost

# MQTT broker port (default: 1883 for unencrypted, 8883 for TLS)
MQTT_PORT=1883

# Optional: MQTT username for authentication
# Leave blank if broker allows anonymous connections
# MQTT_USERNAME=username

# Optional: MQTT password for authentication
# Leave blank if broker allows anonymous connections
# MQTT_PASSWORD=password

# MQTT topic prefix for sensor subscriptions
# The system will subscribe to horowhenua/sensors/# by default
MQTT_TOPIC_PREFIX=horowhenua/sensors

# ============================================================================
# STORAGE CONFIGURATION (Local Knowledge Base)
# ============================================================================

# Directory for storing captured media (video frames, audio clips)
# Development: ./telemetry_data/media
# Production on RPi 5 with NVMe: /mnt/nvme/telemetry_data/media
MEDIA_DIR=./telemetry_data/media

# Directory for storing sensor telemetry logs (JSON)
# Development: ./telemetry_data/sensor_logs
# Production on RPi 5 with NVMe: /mnt/nvme/telemetry_data/sensor_logs
SENSOR_LOGS_DIR=./telemetry_data/sensor_logs

# Media retention period in hours
# Files older than this will be deleted during pruning
# Typical: 48 (2 days) for RPi with limited storage
# Can be increased on systems with more storage (96, 168)
MEDIA_RETENTION_HOURS=48

# Critical disk usage threshold (percentage)
# System will log critical alert if disk usage exceeds this
# Typical: 85.0 (alert at 85% usage)
CRITICAL_DISK_USAGE_PCT=85.0

# ============================================================================
# CAMERA CONFIGURATION (CSI Camera - RPi)
# ============================================================================

# Camera device index (OpenCV)
# 0 = /dev/video0 (primary camera, CSI camera on RPi)
# 1 = /dev/video1 (USB camera if connected)
CAMERA_DEVICE_INDEX=0

# Video capture frame rate (fps)
# Typical: 30 fps for real-time monitoring
# Lower (15) for slower systems, higher (60) for faster processing
CAMERA_FPS=30

# ============================================================================
# AUDIO CONFIGURATION (Microphone - USB or I2S)
# ============================================================================

# Audio sample rate in Hz
# Typical: 16000 Hz (16 kHz) for speech/anomaly detection
# Options: 8000, 16000, 44100, 48000
AUDIO_SAMPLE_RATE=16000

# Audio buffer chunk size in samples
# Typical: 4096 samples (~256ms at 16kHz)
AUDIO_CHUNK_SIZE=4096

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Development: DEBUG
# Production: INFO or WARNING
LOG_LEVEL=INFO

# Log file path (optional)
# Leave blank to log only to console
# Absolute path: /var/log/blue-moon/portal.log
# Relative path: ./logs/portal.log
# LOG_FILE=

# ============================================================================
# HARDWARE CONTROL (GPIO/I2C - Production)
# ============================================================================

# Pump control GPIO pin (BCM numbering on RPi)
# Typical: GPIO17, GPIO27
# Example: PUMP_GPIO_PIN=17
# PUMP_GPIO_PIN=17

# Pump PWM frequency (Hz) for variable flow control
# Typical: 1000 Hz
# PUMP_PWM_FREQUENCY=1000

# Lighting control GPIO pin
# Typical: GPIO22, GPIO23
# Example: LIGHTING_GPIO_PIN=22
# LIGHTING_GPIO_PIN=22

# Lighting PWM frequency (Hz)
# Typical: 1000 Hz
# LIGHTING_PWM_FREQUENCY=1000

# Alert/buzzer GPIO pin (for critical warnings)
# Typical: GPIO27
# ALERT_GPIO_PIN=27

# ============================================================================
# FEATURE FLAGS (Phase 2+)
# ============================================================================

# Enable hardware enforcement (pump/lighting control)
# false = simulate actions only (development/testing)
# true = actually control hardware (production)
ENABLE_HARDWARE_CONTROL=false

# Enable image/audio recording and storage
# false = process only, don't save media files
# true = save all captured frames and audio clips
ENABLE_MEDIA_RECORDING=true

# Enable yield prediction model
# Requires additional model files and dependencies
ENABLE_YIELD_PREDICTION=false

# ============================================================================
# MONITORING & ALERTS
# ============================================================================

# Email address for critical alerts
# Leave blank to disable email alerts
# ALERT_EMAIL=ops@example.com

# Slack webhook URL for notifications (Phase 2+)
# Leave blank to disable Slack alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Alert webhook for custom integrations (Phase 2+)
# CUSTOM_ALERT_WEBHOOK=https://...
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# OPTIONAL: HARDWARE-SPECIFIC
# ============================================================================
# Enable GPU/NPU acceleration (Hailo AI Top Hat)
# OLLAMA_NUM_GPU=1

# Enable debugging mode (verbose logging, mock data if hardware unavailable)
# DEBUG_MODE=false

# ============================================================================
# PORTAL SECOPS CONFIGURATION
# ============================================================================

# Access Control
PORTAL_SESSION_SECRET=generate_a_cryptographic_random_string_here
ALLOWED_CORS_ORIGINS=https://localhost,https://192.168.1.100

# Rate Limiting (Prevent Brute Force)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50

# Edge Network Routing
WEAVER_EDGE_URL=ssl://your-weaver-node-ip:8883

# GitHub Packages Authentication
# Generate a classic PAT token with 'read:packages' permissions and insert it in your real .env
GITHUB_TOKEN=your_github_personal_access_token_here



# ============================================================================
# BLUE MOON LOOP POLICY (edge optimisations)
# ============================================================================
# Minimum seconds between full LLM planning cycles
BLUE_MOON_MIN_PLAN_INTERVAL_SEC=30
# Skip AV capture when sensor analysis is healthy/stable
BLUE_MOON_ADAPTIVE_AV=false
# Cap flywheel JSONL growth on SD cards
BLUE_MOON_FLYWHEEL_MAX_BYTES=5242880
BLUE_MOON_FLYWHEEL_KEEP_LINES=2000
